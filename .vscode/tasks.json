{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Delphi: Build Debug Win64",
      "type": "shell",
      "command": "${workspaceFolder}\\Code\\tools\\build_delphi.cmd",
      "args": ["Debug", "Win64"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$msCompile"],
      "options": {
        "cwd": "${workspaceFolder}\\Code"
      }
    },
    {
      "label": "Delphi: Build Release Win64",
      "type": "shell",
      "command": "${workspaceFolder}\\Code\\tools\\build_delphi.cmd",
      "args": ["Release", "Win64"],
      "problemMatcher": ["$msCompile"],
      "options": {
        "cwd": "${workspaceFolder}\\Code"
      }
    }
  ]
}
